  <content contentuid="hf1a200000000005e" version="1">额外攻击</content>
  <content contentuid="hf1a200000000005f" version="1">执行攻击动作时，每回合可攻击两次。</content>
  <content contentuid="hf1a2000000000060" version="1">额外攻击（二）</content>
